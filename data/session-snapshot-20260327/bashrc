# Prompt JARVIS dynamique avec indicateurs
_jarvis_prompt() {
    local exit_code=$?
    local CYAN='\[\e[0;36m\]'
    local GREEN='\[\e[0;32m\]'
    local RED='\[\e[0;31m\]'
    local YELLOW='\[\e[0;33m\]'
    local BLUE='\[\e[0;34m\]'
    local WHITE='\[\e[1;37m\]'
    local GRAY='\[\e[0;37m\]'
    local NC='\[\e[0m\]'

    # Indicateur de succès/échec
    local status_icon
    if [ $exit_code -eq 0 ]; then
        status_icon="${GREEN}✓${NC}"
    else
        status_icon="${RED}✗${NC}"
    fi

    # Git branch (si dans un repo)
    local git_branch=""
    if git rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
        git_branch=" ${GRAY}⎇ $(git branch --show-current 2>/dev/null)${NC}"
    fi

    # Virtualenv
    local venv=""
    if [ -n "$VIRTUAL_ENV" ]; then
        venv=" ${YELLOW}⬡${NC}"
    fi

    PS1="${CYAN}╭─ ${WHITE}JARVIS${CYAN} │${NC} ${BLUE}\w${NC}${git_branch}${venv}\n${CYAN}╰─${NC} ${status_icon} \$ "
}
PROMPT_COMMAND='_jarvis_prompt'

