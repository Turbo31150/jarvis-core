{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest",
        "--cdp-endpoint",
        "http://127.0.0.1:9222"
      ],
      "env": {
        "CDP_TARGET_URL": "http://127.0.0.1:9222"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--cdp-endpoint",
        "http://127.0.0.1:9222"
      ],
      "env": {
        "DISPLAY": ":0"
      }
    }
  }
}
